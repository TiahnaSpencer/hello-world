#include <iostream>
#include <cstdlib>
#include <ctime>
using namespace std;
int main()
{
	int numGuess = 0;
	
	//generate a new number each time the program runs
	srand(time(0));

	//generate random number between 1 and 100
	int randomNum = rand() % 101;

	cout << "Guess the number between 1 and 100!\n";

	do {
	    
	    //prevents letters and number higher than 100 or lower than 0
	    if (cin.fail()) {
	        cin.clear ();
	        cin.ignore( 10000, '\n');
	        cout<< "Invalid Input, Try Again!";
	        continue;
	    }
	    
	cin >> numGuess;
	if (numGuess < randomNum) {
			cout << "Go Higher\n";
		}
	
		if (numGuess > randomNum) {
			cout << "Go Lower\n";
		}
		if (numGuess == randomNum) {
			cout << "Correct!";
		}
	 
}
    while (numGuess != randomNum);
}
